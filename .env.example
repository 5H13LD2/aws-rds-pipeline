# Example environment variables for AWS ecommerce data platform

# Airflow Docker runtime user
AIRFLOW_UID=50000

# Airflow source Postgres connection
POSTGRES_RDS_LOGIN=airflow
POSTGRES_RDS_PASSWORD=airflow
POSTGRES_RDS_HOST=postgres
POSTGRES_RDS_PORT=5432
POSTGRES_RDS_SCHEMA=airflow

# Database
RDS_HOST=
RDS_PORT=5432
RDS_DB=
RDS_USER=
RDS_PASSWORD=

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
S3_BUCKET=
S3_BRONZE_BUCKET=

# Redshift
REDSHIFT_HOST=
REDSHIFT_PORT=5439
REDSHIFT_DB=
REDSHIFT_USER=
REDSHIFT_PASSWORD=
